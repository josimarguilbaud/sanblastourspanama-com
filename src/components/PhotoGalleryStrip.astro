---
interface Props {
  title: string;
  titleAccent: string;
  images: { src: string; alt: string }[];
}

const { title, titleAccent, images } = Astro.props;
---

<section class="bg-teal/5 py-10">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col gap-6 rounded-[2rem] border-2 border-dashed border-teal/30 bg-white p-6 sm:flex-row sm:items-center sm:p-8">
      <div class="shrink-0">
        <p class="font-display text-2xl font-semibold leading-tight text-amber">{title}</p>
        <p class="font-display text-2xl font-semibold leading-tight text-deep">{titleAccent}</p>
      </div>
      <div class="flex gap-3 overflow-x-auto">
        {images.map((img) => (
          <div class="h-24 w-24 shrink-0 overflow-hidden rounded-xl sm:h-28 sm:w-28">
            <img src={img.src} alt={img.alt} loading="lazy" class="h-full w-full object-cover" />
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
