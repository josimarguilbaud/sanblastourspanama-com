---
// This site sends 100% of booking traffic to WhatsApp — no online widget,
// no online payment here. Coordinating by WhatsApp is a deliberate choice
// per the client, not a stopgap. This number is specific to this site
// (sanblastourspanama.com), separate from the main reservas.sanblastravel.com
// app's chatbot number.
import { defaultLocale } from '../i18n/ui';

const WHATSAPP_NUMBER = '50764684720';

interface Props {
  label?: string;
  /** Prefilled WhatsApp message. Defaults to a generic locale-aware inquiry. */
  message?: string;
  class?: string;
}

const defaultMessages: Record<string, string> = {
  en: "Hi! I'd like more info about San Blas tours.",
  es: '¡Hola! Quiero información sobre los tours a San Blas.',
  de: 'Hallo! Ich hätte gerne mehr Informationen zu San-Blas-Touren.',
  fr: "Bonjour ! J'aimerais plus d'informations sur les excursions à San Blas.",
  'pt-br': 'Olá! Gostaria de mais informações sobre os passeios em San Blas.',
};

const locale = Astro.currentLocale ?? defaultLocale;
const {
  label = 'Message Us on WhatsApp',
  message = defaultMessages[locale] ?? defaultMessages[defaultLocale],
  class: className = '',
} = Astro.props;

const href = `https://wa.me/${WHATSAPP_NUMBER}?text=${encodeURIComponent(message)}`;
---

<a
  href={href}
  target="_blank"
  rel="noopener"
  class={`inline-flex items-center justify-center gap-2 rounded-full bg-coral px-6 py-3 font-heading font-bold text-white shadow-lg shadow-coral/30 transition hover:bg-coraldark ${className}`}
>
  <svg class="h-5 w-5 shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
    <path d="M12.04 2c-5.52 0-10 4.48-10 10 0 1.77.46 3.5 1.34 5.02L2 22l5.13-1.35A9.96 9.96 0 0012.04 22c5.52 0 10-4.48 10-10s-4.48-10-10-10zm0 18.15a8.1 8.1 0 01-4.14-1.13l-.3-.18-3.05.8.81-2.97-.2-.31a8.13 8.13 0 01-1.25-4.36c0-4.49 3.65-8.14 8.14-8.14 2.17 0 4.21.85 5.75 2.39a8.08 8.08 0 012.38 5.75c0 4.49-3.66 8.15-8.14 8.15zm4.47-6.1c-.24-.12-1.45-.72-1.68-.8-.22-.08-.39-.12-.55.12-.16.24-.63.8-.78.97-.14.16-.29.18-.53.06-.24-.12-1.02-.38-1.94-1.2-.72-.64-1.2-1.43-1.35-1.67-.14-.24-.02-.37.11-.49.11-.11.24-.29.36-.43.12-.14.16-.24.24-.4.08-.16.04-.31-.02-.43-.06-.12-.55-1.32-.75-1.81-.2-.48-.4-.41-.55-.42-.14-.01-.31-.01-.47-.01-.16 0-.43.06-.65.31-.22.24-.86.84-.86 2.04 0 1.2.88 2.37 1 2.53.12.16 1.73 2.64 4.2 3.7.59.25 1.05.4 1.4.52.59.19 1.13.16 1.55.1.47-.07 1.45-.59 1.66-1.16.2-.57.2-1.06.14-1.16-.06-.1-.22-.16-.46-.28z"/>
  </svg>
  {label}
</a>
