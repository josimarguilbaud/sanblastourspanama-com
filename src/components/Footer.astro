---
import { useTranslations, localizedPath, locales, languageNames, defaultLocale } from '../i18n/ui';
import { navShortcuts } from '../i18n/nav';
import BookingCta from './BookingCta.astro';

const locale = Astro.currentLocale ?? defaultLocale;
const t = useTranslations(locale);
const year = new Date().getFullYear();

const hasFullContent = locale === 'en' || locale === 'es';
const islandLinks = hasFullContent ? navShortcuts[locale as 'en' | 'es'].islands.slice(0, 5) : [];

// Legal pages live on this site (src/pages/legal/*, src/pages/{locale}/legal/*)
// so they share this site's design and never send visitors to another domain.
const legalLinksByLocale: Record<string, { href: string; label: string }[]> = {
  en: [
    { href: '/legal/terms', label: 'Terms & Conditions' },
    { href: '/legal/cancellation-policy', label: 'Cancellation Policy' },
    { href: '/legal/privacy', label: 'Privacy Policy' },
  ],
  es: [
    { href: '/es/legal/terminos', label: 'Términos y Condiciones' },
    { href: '/es/legal/politica-cancelacion', label: 'Política de Cancelación' },
    { href: '/es/legal/privacidad', label: 'Privacidad' },
  ],
  de: [
    { href: '/de/legal/agb', label: 'AGB' },
    { href: '/de/legal/stornierung', label: 'Stornierungsbedingungen' },
    { href: '/de/legal/datenschutz', label: 'Datenschutz' },
  ],
  fr: [
    { href: '/fr/legal/conditions', label: 'Conditions Générales' },
    { href: '/fr/legal/annulation', label: "Politique d'Annulation" },
    { href: '/fr/legal/confidentialite', label: 'Confidentialité' },
  ],
  'pt-br': [
    { href: '/pt-br/legal/termos', label: 'Termos e Condições' },
    { href: '/pt-br/legal/cancelamento', label: 'Política de Cancelamento' },
    { href: '/pt-br/legal/privacidade', label: 'Privacidade' },
  ],
};
const legalLinks = legalLinksByLocale[locale] ?? legalLinksByLocale.en;
---

<footer class="bg-sand">
  <div class="mx-auto max-w-7xl px-4 pb-10 pt-16 sm:px-6 lg:px-8">
    <div class="grid gap-10 sm:grid-cols-2 lg:grid-cols-5">
      <div class="lg:col-span-2">
        <a href={localizedPath(locale, '/')} class="flex items-center gap-2">
          <span class="text-2xl">🌴</span>
          <span class="font-script text-3xl font-bold leading-none text-lime">San Blas</span>
        </a>
        <p class="mt-3 max-w-xs text-sm text-deep/60">{t('footer.tagline')}</p>
        <div class="mt-4 flex gap-3">
          <a href="https://www.instagram.com/" aria-label="Instagram" class="flex h-9 w-9 items-center justify-center rounded-full border-2 border-amber text-deep transition hover:bg-amber hover:text-white">
            <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073z"/><path d="M12 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8z"/><circle cx="18.406" cy="5.594" r="1.44"/></svg>
          </a>
          <a href="https://www.facebook.com/" aria-label="Facebook" class="flex h-9 w-9 items-center justify-center rounded-full border-2 border-amber text-deep transition hover:bg-amber hover:text-white">
            <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.879V14.89h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.989C18.343 21.128 22 16.991 22 12z"/></svg>
          </a>
        </div>
      </div>

      <div>
        <p class="font-heading font-bold text-deep">{t('footer.explore')}</p>
        <ul class="mt-3 space-y-2 text-sm text-deep/70">
          <li><a href={localizedPath(locale, '/islands')} class="hover:text-lime">{t('footer.allIslands')}</a></li>
          <li><a href={localizedPath(locale, '/tours')} class="hover:text-lime">{t('footer.toursAndPrices')}</a></li>
          <li><a href={localizedPath(locale, '/guides')} class="hover:text-lime">{t('nav.guides')}</a></li>
          <li><a href={localizedPath(locale, '/blog')} class="hover:text-lime">{t('nav.blog')}</a></li>
          <li><a href={localizedPath(locale, '/faq')} class="hover:text-lime">{t('nav.faq')}</a></li>
        </ul>
      </div>

      {islandLinks.length > 0 && (
        <div>
          <p class="font-heading font-bold text-deep">{t('nav.islands')}</p>
          <ul class="mt-3 space-y-2 text-sm text-deep/70">
            {islandLinks.map((item) => (
              <li><a href={localizedPath(locale, item.href)} class="hover:text-lime">{item.label}</a></li>
            ))}
          </ul>
        </div>
      )}

      <div>
        <p class="font-heading font-bold text-deep">{locale === 'de' ? 'Rechtliches' : locale === 'fr' ? 'Mentions Légales' : 'Legal'}</p>
        <ul class="mt-3 space-y-2 text-sm text-deep/70">
          {legalLinks.map((item) => (
            <li><a href={item.href} class="hover:text-lime">{item.label}</a></li>
          ))}
        </ul>
      </div>
    </div>

    <div class="mt-12 grid gap-4 sm:grid-cols-2">
      <div class="flex items-center gap-3">
        <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-lime/10 text-lime">
          <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12.04 2c-5.52 0-10 4.48-10 10 0 1.77.46 3.5 1.34 5.02L2 22l5.13-1.35A9.96 9.96 0 0012.04 22c5.52 0 10-4.48 10-10s-4.48-10-10-10zm0 18.15a8.1 8.1 0 01-4.14-1.13l-.3-.18-3.05.8.81-2.97-.2-.31a8.13 8.13 0 01-1.25-4.36c0-4.49 3.65-8.14 8.14-8.14 2.17 0 4.21.85 5.75 2.39a8.08 8.08 0 012.38 5.75c0 4.49-3.66 8.15-8.14 8.15z"/></svg>
        </span>
        <a href="https://wa.me/50764684720" target="_blank" rel="noopener" class="font-script text-xl text-deep hover:text-lime">+507 6468-4720</a>
      </div>
      <div class="flex items-center gap-3">
        <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-lime/10 text-lime">
          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
        </span>
        <a href="mailto:info@sanblastravel.com" class="font-script text-xl text-deep hover:text-lime">info@sanblastravel.com</a>
      </div>
    </div>

    <div class="mt-10 flex flex-col items-center justify-between gap-4 rounded-3xl bg-deep px-6 py-6 sm:flex-row sm:px-10">
      <div>
        <p class="font-display text-2xl text-white">Plan Your Trip <span class="text-amber">Now!</span></p>
        <p class="mt-1 text-sm text-sand/70">Message us on WhatsApp — a real person answers, same day.</p>
      </div>
      <BookingCta label="Book Now" class="!bg-lime !shadow-lime/30 hover:!bg-limedark shrink-0" />
    </div>

    <div class="mt-8 flex flex-col items-center justify-between gap-3 border-t border-deep/10 pt-6 text-center sm:flex-row sm:text-left">
      <p class="text-xs text-deep/50">&copy; {year} <span class="font-bold text-amber">San Blas Travel</span>. All rights reserved.</p>
      <ul class="flex flex-wrap justify-center gap-x-4 gap-y-1 text-xs">
        {locales.map((l) => (
          <li><a href={localizedPath(l, '/')} class="text-deep/50 hover:text-lime">{languageNames[l]}</a></li>
        ))}
      </ul>
    </div>
  </div>
</footer>
