---
interface Item {
  href: string;
  heroImage: string;
  title: string;
  subtitle?: string;
}

interface Props {
  title: string;
  items: Item[];
}

const { title, items } = Astro.props;
---

{items.length > 0 && (
  <section class="mx-auto max-w-3xl px-4 pb-4 sm:px-6 lg:px-8">
    <h2 class="font-heading text-xl font-bold text-deep">{title}</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      {items.map((item) => (
        <a href={item.href} class="group overflow-hidden rounded-xl bg-white shadow-sm ring-1 ring-deep/5 transition hover:shadow-md">
          <div class="h-28 overflow-hidden">
            <img src={item.heroImage} alt={item.title} loading="lazy" class="h-full w-full object-cover transition duration-300 group-hover:scale-105" />
          </div>
          <div class="p-3">
            <p class="text-sm font-bold text-deep group-hover:text-teal">{item.title}</p>
            {item.subtitle && <p class="mt-0.5 text-xs text-deep/50">{item.subtitle}</p>}
          </div>
        </a>
      ))}
    </div>
  </section>
)}
