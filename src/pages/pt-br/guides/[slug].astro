---
import { getCollection, render } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';
import BookingCta from '../../../components/BookingCta.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import RelatedCards from '../../../components/RelatedCards.astro';
import { localesForSlug } from '../../../i18n/content';
import { useTranslations } from '../../../i18n/ui';

export async function getStaticPaths() {
  const allGuides = await getCollection('guides');
  return allGuides
    .filter((entry) => entry.id.startsWith('pt-br/'))
    .map((entry) => ({
      params: { slug: entry.id.replace(/^pt-br\//, '') },
      props: { entry },
    }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const { title, heroImage, relatedGuideSlugs, relatedIslandSlugs, seoTitle, seoDescription } = entry.data;
const slug = entry.id.replace(/^pt-br\//, '');
const t = useTranslations('pt-br');

const allGuides = await getCollection('guides');
const availableLocales = localesForSlug(allGuides, slug);

const relatedGuides = allGuides
  .filter((g) => g.id.startsWith('pt-br/') && relatedGuideSlugs.includes(g.id.replace(/^pt-br\//, '')))
  .map((g) => ({
    href: `/pt-br/guides/${g.id.replace(/^pt-br\//, '')}`,
    heroImage: g.data.heroImage ?? '/favicon.svg',
    title: g.data.title,
  }));

const allIslands = await getCollection('islands');
const relatedIslands = allIslands
  .filter((i) => i.id.startsWith('pt-br/') && relatedIslandSlugs.includes(i.id.replace(/^pt-br\//, '')))
  .map((i) => ({
    href: `/pt-br/islands/${i.id.replace(/^pt-br\//, '')}`,
    heroImage: i.data.heroImage,
    title: i.data.name,
  }));
---

<Layout
  title={seoTitle ?? `${title} — Ilhas de San Blas`}
  description={seoDescription ?? title}
  image={heroImage}
  path={`/guides/${slug}`}
  availableLocales={availableLocales}
>
  {heroImage && (
    <div class="h-[35vh] min-h-[260px] w-full overflow-hidden">
      <img src={heroImage} alt={title} class="h-full w-full object-cover" />
    </div>
  )}

  <Breadcrumbs items={[{ label: 'Início', href: '/' }, { label: 'Guias de Viagem', href: '/guides' }, { label: title }]} />

  <article class="mx-auto max-w-3xl px-4 pb-12 pt-4 sm:px-6 lg:px-8">
    <h1 class="font-display text-4xl font-semibold text-deep sm:text-5xl">{title}</h1>

    <div class="prose prose-headings:font-heading prose-headings:text-deep prose-a:text-teal mt-8 max-w-none">
      <Content />
    </div>

    <div class="mt-12 rounded-3xl bg-deep p-8 text-center">
      <p class="font-heading text-xl font-bold text-white">Pronto para planejar sua viagem?</p>
      <p class="mt-2 text-sand/70">Fale conosco no WhatsApp — uma pessoa real ajuda você.</p>
      <BookingCta label={t('cta.book')} class="mt-5 !bg-lime !shadow-lime/30 hover:!bg-limedark" />
    </div>
  </article>

  <RelatedCards title="Ilhas para Combinar" items={relatedIslands} />
  <RelatedCards title="Guias Relacionados" items={relatedGuides} />
</Layout>
