---
import { getCollection } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';

const allGuides = await getCollection('guides');
const guides = allGuides.filter((entry) => entry.id.startsWith('fr/'));
---

<Layout
  title="Guides de Voyage San Blas — Informations Pratiques | Îles de San Blas"
  description="Guides de voyage pratiques pour San Blas : comment s'y rendre, quoi apporter, la meilleure période pour visiter et l'étiquette de la culture Guna."
  path="/guides"
  availableLocales={['en', 'es', 'fr']}
>
  <section class="mx-auto max-w-5xl px-4 py-16 sm:px-6 lg:px-8">
    <h1 class="font-display text-4xl font-semibold text-deep sm:text-5xl">Guides de Voyage</h1>
    <p class="mt-4 max-w-2xl text-lg text-deep/70">
      Tout le pratique dont vous avez besoin avant de partir — directement des notes de l'opérateur lui-même.
    </p>

    <div class="mt-12 grid gap-6 sm:grid-cols-2">
      {guides.map((guide) => {
        const slug = guide.id.replace(/^fr\//, '');
        return (
          <a
            href={`/fr/guides/${slug}`}
            class="group overflow-hidden rounded-2xl bg-white shadow-sm ring-1 ring-deep/5 transition hover:shadow-lg"
          >
            {guide.data.heroImage && (
              <div class="h-40 overflow-hidden">
                <img
                  src={guide.data.heroImage}
                  alt={guide.data.title}
                  loading="lazy"
                  class="h-full w-full object-cover transition duration-300 group-hover:scale-105"
                />
              </div>
            )}
            <div class="p-5">
              <h2 class="font-heading text-lg font-bold text-deep">{guide.data.title}</h2>
            </div>
          </a>
        );
      })}
    </div>
  </section>
</Layout>
