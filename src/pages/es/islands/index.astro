---
import { getCollection } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';

const allIslands = await getCollection('islands');
const islands = allIslands
  .filter((entry) => entry.id.startsWith('es/'))
  .sort((a, b) => a.data.name.localeCompare(b.data.name));
---

<Layout
  title="Islas de San Blas — Guía Completa de 30+ Islas en Guna Yala | Islas de San Blas"
  description="Explora cada isla de San Blas que vale la pena visitar: Chichime, Isla Diablo, Perro Chico, Cayos Limones y más — con qué esperar, etiquetas de 'ideal para' y cómo reservar un tour que las visite."
  path="/islands"
  availableLocales={['en', 'es']}
>
  <section class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
    <h1 class="font-display text-4xl font-semibold text-deep sm:text-5xl">Las Islas de San Blas</h1>
    <p class="mt-4 max-w-2xl text-lg text-deep/70">
      Guna Yala tiene más de 30 islas y cayos con nombre propio, cada uno con su propio carácter —
      desde arrecifes de snorkel hasta comunidades pescadoras Guna. Esta es la guía completa, que
      seguimos ampliando.
    </p>

    <div class="mt-12 grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
      {islands.map((island) => {
        const slug = island.id.replace(/^es\//, '');
        return (
          <a
            href={`/es/islands/${slug}`}
            class="group overflow-hidden rounded-2xl bg-white shadow-sm ring-1 ring-deep/5 transition hover:shadow-lg"
          >
            <div class="h-48 overflow-hidden">
              <img
                src={island.data.heroImage}
                alt={island.data.name}
                loading="lazy"
                class="h-full w-full object-cover transition duration-300 group-hover:scale-105"
              />
            </div>
            <div class="p-5">
              <h2 class="font-heading text-lg font-bold text-deep">{island.data.name}</h2>
              {island.data.sector && <p class="mt-1 text-sm text-teal">{island.data.sector}</p>}
              <div class="mt-3 flex flex-wrap gap-1.5">
                {island.data.bestFor.slice(0, 3).map((tag) => (
                  <span class="rounded-full bg-sand px-2.5 py-1 text-xs font-medium text-deep/70">
                    {tag.replace(/-/g, ' ')}
                  </span>
                ))}
              </div>
            </div>
          </a>
        );
      })}
    </div>
  </section>
</Layout>
