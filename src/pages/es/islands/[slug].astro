---
import { getCollection, render } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';
import BookingCta from '../../../components/BookingCta.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import RelatedCards from '../../../components/RelatedCards.astro';
import { localesForSlug } from '../../../i18n/content';
import { useTranslations } from '../../../i18n/ui';

export async function getStaticPaths() {
  const allIslands = await getCollection('islands');
  return allIslands
    .filter((entry) => entry.id.startsWith('es/'))
    .map((entry) => ({
      params: { slug: entry.id.replace(/^es\//, '') },
      props: { entry },
    }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const { name, sector, heroImage, bestFor, isInhabited, relatedTourKeys, seoTitle, seoDescription } = entry.data;
const slug = entry.id.replace(/^es\//, '');
const t = useTranslations('es');

const allIslands = await getCollection('islands');
const availableLocales = localesForSlug(allIslands, slug);

const allTours = await getCollection('tours');
const relatedTours = allTours
  .filter((tr) => tr.id.startsWith('es/') && relatedTourKeys.includes(tr.data.tourKey ?? ''))
  .map((tr) => ({
    href: `/es/tours/${tr.id.replace(/^es\//, '')}`,
    heroImage: tr.data.heroImage,
    title: tr.data.name,
    subtitle: tr.data.category === 'day-tour' ? 'Pasadía' : 'Estadía Nocturna',
  }));

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'TouristAttraction',
  name,
  image: heroImage,
  description: seoDescription,
  ...(entry.data.lat && entry.data.lng
    ? { geo: { '@type': 'GeoCoordinates', latitude: entry.data.lat, longitude: entry.data.lng } }
    : {}),
};
---

<Layout
  title={seoTitle ?? `${name} — Islas de San Blas`}
  description={seoDescription ?? `Todo lo que necesitas saber sobre ${name} en San Blas, Panamá.`}
  image={heroImage}
  path={`/islands/${slug}`}
  availableLocales={availableLocales}
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <div class="h-[45vh] min-h-[320px] w-full overflow-hidden">
    <img src={heroImage} alt={name} class="h-full w-full object-cover" />
  </div>

  <Breadcrumbs items={[{ label: 'Inicio', href: '/' }, { label: 'Islas', href: '/islands' }, { label: name }]} />

  <article class="mx-auto max-w-3xl px-4 pb-12 pt-4 sm:px-6 lg:px-8">
    <p class="text-sm font-semibold uppercase tracking-wide text-teal">
      {sector} {isInhabited ? '· Comunidad Guna' : '· Cayo deshabitado'}
    </p>
    <h1 class="mt-2 font-display text-4xl font-semibold text-deep sm:text-5xl">{name}</h1>

    <div class="mt-4 flex flex-wrap gap-2">
      {bestFor.map((tag: string) => (
        <span class="rounded-full bg-lime/10 px-3 py-1 text-sm font-medium text-limedark">
          {tag.replace(/-/g, ' ')}
        </span>
      ))}
    </div>

    <div class="prose prose-headings:font-heading prose-headings:text-deep prose-a:text-teal mt-8 max-w-none">
      <Content />
    </div>

    <div class="mt-12 rounded-3xl bg-deep p-8 text-center">
      <p class="font-heading text-xl font-bold text-white">¿Listo para conocer {name} en persona?</p>
      <p class="mt-2 text-sand/70">Escríbenos por WhatsApp — una persona real te ayuda a encontrar un tour que incluya esta isla.</p>
      <BookingCta label={t('cta.book')} message={`¡Hola! Me interesa un tour de San Blas que visite ${name}.`} class="mt-5 !bg-lime !shadow-lime/30 hover:!bg-limedark" />
    </div>
  </article>

  <RelatedCards title="Tours que Visitan Esta Isla" items={relatedTours} />
</Layout>
